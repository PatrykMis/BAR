    <!-- Native sample rate screen -->
    <string name="native_sample_rate_about_title">Acerca de esta prueba</string>
    <string name="native_sample_rate_about_desc">Android no expone una frecuencia de muestreo nativa fiable para el micrófono. BAR compara los tamaños mínimos de búfer para 48000 Hz y 44100 Hz. Es una heurística; usa los detalles de logcat para diagnosticar un dispositivo.</string>
    <string name="native_sample_rate_result_title">Resultado</string>
    <string name="native_sample_rate_result_not_tested">Ejecuta la prueba para estimar la frecuencia de muestreo nativa.</string>
    <string name="native_sample_rate_run_test">Ejecutar prueba</string>
    <string name="native_sample_rate_run_test_desc">Compara los tamaños mínimos de búfer y escribe los intentos detallados en logcat.</string>
    <string name="native_sample_rate_result_detected">Detectado por heurística de búfer: %1$d Hz\nCanal seleccionado: %2$s\nCompletado en: %4$d ms\nDetalles registrados con la etiqueta: %3$s</string>
    <string name="native_sample_rate_result_fallback">Sin resultado concluyente de búfer; se usa el valor de reserva: %1$d Hz\nCompletado en: %3$d ms\nDetalles registrados con la etiqueta: %2$s</string>

