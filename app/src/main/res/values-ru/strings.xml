    <!-- Native sample rate screen -->
    <string name="native_sample_rate_about_title">Об этом тесте</string>
    <string name="native_sample_rate_about_desc">Android не предоставляет надежную родную частоту дискретизации микрофона. BAR сравнивает минимальные размеры буфера для 48000 Hz и 44100 Hz. Это эвристика; для диагностики устройства используйте подробности из logcat.</string>
    <string name="native_sample_rate_result_title">Результат</string>
