    <string name="audio_sample_format_pcm_32bit">32-bit PCM</string>
    <string name="audio_sample_format_pcm_float">32-bit float</string>
    <string name="bit_depth_warning_title">更高位深度无法保证</string>
    <string name="bit_depth_warning_message">即使设备内部以较低精度采集音频，Android 也可能允许 24-bit、32-bit 或 float 录音。在这种情况下，额外的位可能只是填充或推导出来的，并不代表真实的麦克风细节。若需要最可预期的兼容性，请使用 16-bit PCM。</string>
    <string name="dialog_do_not_show_again">不再显示此消息</string>
    <string name="audio_source_unprocessed">原始（未处理）</string>
    <string name="audio_source_voice_recognition">语音识别</string>
    <string name="audio_source_microphone">麦克风</string>
    <string name="audio_source_unsupported_unprocessed_summary">%s，此设备未声明支持</string>
    <string name="audio_source_unsupported_unprocessed_title">原始输入无法保证</string>
    <string name="audio_source_unsupported_unprocessed_message">此设备未报告支持原始未处理输入。Android 仍允许使用此来源，但不保证信号确实未经处理。如果你需要没有自动增益控制或降噪的输入，请尝试语音识别。</string>
    <string name="audio_channels_mono">单声道</string>
    <string name="audio_channels_stereo">立体声</string>

    <!-- Native sample rate screen -->
    <string name="native_sample_rate_about_title">关于此测试</string>
    <string name="native_sample_rate_about_desc">Android 不提供可靠的麦克风原生采样率。BAR 会比较 48000 Hz 和 44100 Hz 的最小缓冲区大小。这只是启发式判断；诊断设备时请查看 logcat 中的详细信息。</string>
    <string name="native_sample_rate_result_title">结果</string>
    <string name="native_sample_rate_result_not_tested">运行测试以估算原生采样率。</string>
    <string name="native_sample_rate_run_test">运行测试</string>
    <string name="native_sample_rate_run_test_desc">比较最小缓冲区大小，并将每次尝试的详细信息写入 logcat。</string>
    <string name="native_sample_rate_result_detected">缓冲区启发式检测结果：%1$d Hz\n所选声道：%2$s\n完成用时：%4$d ms\n详细信息已使用此标签记录：%3$s</string>
    <string name="native_sample_rate_result_fallback">没有明确的缓冲区结果；使用后备值：%1$d Hz\n完成用时：%3$d ms\n详细信息已使用此标签记录：%2$s</string>

