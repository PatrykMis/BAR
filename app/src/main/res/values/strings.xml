    <!-- Native sample rate screen -->
    <string name="native_sample_rate_about_title">About this test</string>
    <string name="native_sample_rate_about_desc">Android does not expose a reliable microphone native sample rate. BAR compares minimum buffer sizes for 48000 Hz and 44100 Hz. This is a heuristic; use the logcat details when diagnosing a device.</string>
    <string name="native_sample_rate_result_title">Result</string>
    <string name="native_sample_rate_result_not_tested">Run the test to estimate the native sample rate.</string>
    <string name="native_sample_rate_run_test">Run test</string>
    <string name="native_sample_rate_run_test_desc">Compares minimum buffer sizes and writes detailed attempts to logcat.</string>
    <string name="native_sample_rate_result_detected">Detected by buffer heuristic: %1$d Hz\nSelected channel: %2$s\nFinished in: %4$d ms\nDetails logged with tag: %3$s</string>
